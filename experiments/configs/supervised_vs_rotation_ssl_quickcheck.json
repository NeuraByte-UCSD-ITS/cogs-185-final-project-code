{
  "experiment_name": "supervised_vs_rotation_ssl_quickcheck_v1",
  "proposal_alignment": "H1 self-supervised pretraining vs end-to-end supervised under partial observability",
  "seed": 42,
  "device_policy": "cuda_then_mps_then_cpu",
  "data": {
    "split": {
      "train_episodes": 300,
      "val_episodes": 80,
      "test_episodes": 80
    },
    "grid_size_train": 8,
    "grid_size_test": 8,
    "obstacle_count": 1,
    "observation_crop_size": 5,
    "episode_horizon_min": 40,
    "episode_horizon_max": 60,
    "ood": {
      "enabled": true,
      "grid_size_test": 10,
      "obstacle_count": 2,
      "test_episodes": 80
    }
  },
  "model": {
    "embedding_size": 64
  },
  "train": {
    "batch_size": 64,
    "supervised_epochs": 4,
    "ssl_pretrain_epochs": 4,
    "linear_probe_epochs": 3,
    "fine_tune_epochs": 3,
    "learning_rate_supervised": 0.001,
    "learning_rate_ssl": 0.001,
    "learning_rate_linear_probe": 0.01,
    "learning_rate_fine_tune_encoder": 0.0005,
    "learning_rate_fine_tune_head": 0.001
  }
}
